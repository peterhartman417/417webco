---
import Base from "../layouts/Base.astro";
import { SITE } from "../data/site";
---

<Base
  title="Contact"
  description="Text us about your website — we respond fast and give straight answers. Serving Nixa, Ozark, Springfield, Republic, and Battlefield."
>
  <section class="section">
    <div class="wrap">
      <p class="kicker">Contact</p>
      <h1>Text first. We'll take it from there.</h1>
      <p class="lead">
        We're a working studio, not a call center — texting gets you an answer
        fastest, usually the same day.
      </p>

      <div class="grid grid-2">
        <div class="card">
          <h3>Start the conversation</h3>
          <p class="big-phone"><a href={`sms:${SITE.phone}`}>{SITE.phoneDisplay}</a></p>
          <p>Serving {SITE.serviceArea} — and remote-friendly beyond it.</p>
          <a class="btn btn-primary" href={`sms:${SITE.phone}`}>Text us now</a>
        </div>
        <div class="card">
          <h3>What to include</h3>
          <ul>
            <li>Your business name and what you do</li>
            <li>Your current website address, if you have one</li>
            <li>What's bugging you about it (slow? ugly? expensive? can't edit it?)</li>
            <li>Rough timeline, if you have one</li>
          </ul>
          <p class="muted-note">
            That's enough for us to look at it and reply with what we'd do and a
            flat-rate range — free, whether or not you hire us.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .big-phone a {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    text-decoration: none;
  }
  .card ul { padding-left: 1.2rem; color: var(--ink-soft); }
  .card li { margin-bottom: 0.45rem; }
  .muted-note { font-size: 0.9rem; color: var(--ink-soft); }
</style>
