---
import Base from "../layouts/Base.astro";
import { SITE } from "../data/site";
---

<Base
  title="Contact"
  description="Email Peter at 417 Web Co about your website — fast replies, straight answers. Serving Nixa, Ozark, Springfield, Republic, and Battlefield."
>
  <section class="section">
    <div class="wrap">
      <p class="kicker">Contact</p>
      <h1>Email me. I'll take it from there.</h1>
      <p class="lead">
        There's no call center and no sales team — the person reading your email
        is the person who'd build your site. You'll get a thought-out answer,
        usually the same day. No sales calls, ever.
      </p>

      <div class="grid grid-2">
        <div class="card">
          <h3>Start the conversation</h3>
          <p class="big-phone"><a href={`mailto:${SITE.email}`}>{SITE.email}</a></p>
          <p class="muted-note">Either address reaches me — or write me directly: <a href={`mailto:${SITE.emailPersonal}`}>{SITE.emailPersonal}</a></p>
          <p>Serving {SITE.serviceArea} — and remote-friendly beyond it.</p>
          <a class="btn btn-primary" href={`mailto:${SITE.email}`}>Email me</a>
        </div>
        <div class="card">
          <h3>What to include</h3>
          <ul>
            <li>Your business name and what you do</li>
            <li>Your current website address, if you have one</li>
            <li>What's bugging you about it (slow? ugly? expensive? can't edit it?)</li>
            <li>Rough timeline, if you have one</li>
          </ul>
          <p class="muted-note">
            That's enough for me to look at it and reply with what I'd do and a
            flat-rate range — free, whether or not you hire me.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .big-phone a {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 800;
    text-decoration: none;
  }
  .card ul { padding-left: 1.2rem; color: var(--ink-soft); }
  .card li { margin-bottom: 0.45rem; }
  .muted-note { font-size: 0.9rem; color: var(--ink-soft); }
</style>
