---
import { SITE } from "../data/site";
const year = new Date().getFullYear();
---

<footer>
  <div class="wrap cols">
    <div>
      <p class="brand">{SITE.name}</p>
      <p class="muted">{SITE.tagline}.</p>
      <p class="muted">A one-man shop — {SITE.owner}, {SITE.city}</p>
      <p class="muted">Serving {SITE.serviceArea}</p>
    </div>
    <div class="links">
      <a href="/work">Work</a>
      <a href="/services">Services</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </div>
    <div>
      <p class="muted">One email starts it.</p>
      <a class="btn btn-ghost" href={`mailto:${SITE.email}`}>Email {SITE.email}</a>
    </div>
  </div>
  <div class="wrap legal">
    <p class="muted">© {year} {SITE.name}. Built on open source — and yes, I built this site too.</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--line);
    background: var(--bg-raised);
    margin-top: 4rem;
  }
  .cols {
    display: grid;
    gap: 2rem;
    padding-top: 2.5rem;
    padding-bottom: 1.5rem;
  }
  @media (min-width: 760px) {
    .cols { grid-template-columns: 2fr 1fr 1.5fr; }
  }
  .brand { font-family: var(--font-display); font-weight: 800; font-size: 1.1rem; margin-bottom: 0.4rem; }
  .muted { color: var(--ink-soft); font-size: 0.92rem; }
  .links { display: flex; flex-direction: column; gap: 0.45rem; }
  .links a { color: var(--ink-soft); text-decoration: none; font-weight: 600; }
  .links a:hover { color: var(--accent); }
  .legal { padding-bottom: 1.5rem; }
  .legal p { margin: 0; font-size: 0.85rem; }
</style>
